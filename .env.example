# ==============================================
# AgentFlow — Configuration
# ==============================================

# Groq API Key (gratuit sur https://console.groq.com)
# Si absent, l'agent bascule automatiquement sur Ollama
GROQ_API_KEY=your_groq_api_key_here

# Ollama (LLM local - fallback)
# Installer : https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# Langfuse (observabilité - self-hosted)
# Lancer avec : docker compose up -d
LANGFUSE_SECRET_KEY=your_secret_key_here
LANGFUSE_PUBLIC_KEY=your_public_key_here
LANGFUSE_HOST=http://localhost:3000